.container {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 120rpx;
}

/* 顶部产品卡片 */
.product-header {
  margin-bottom: 20rpx;
}

.header-bg {
  background: linear-gradient(135deg, #4ecdc4, #44a3aa);
  padding: 40rpx 30rpx 50rpx;
}

.product-main {
  display: flex;
  gap: 30rpx;
}

.product-image-wrap {
  position: relative;
}

.product-icon {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}

.product-badge-row {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
}

.badge-hot {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  color: #fff;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}

.product-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 15rpx;
}

.type-tag, .level-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stars {
  display: flex;
}

.star {
  color: #ffd700;
  font-size: 26rpx;
}

.rating-text {
  color: #ffd700;
  font-size: 26rpx;
  font-weight: bold;
}

/* 价格区域 */
.price-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #4ecdc4;
  font-weight: bold;
}

.price-num {
  font-size: 48rpx;
  color: #4ecdc4;
  font-weight: bold;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.specs-quick {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.spec-quick-item {
  font-size: 22rpx;
  color: #666;
}

.spec-sep {
  color: #ddd;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
  display: block;
}

/* 手胶类型选择 */
.grip-types-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.grip-type-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.grip-type-card.active {
  border-color: #4ecdc4;
  background: rgba(78, 205, 196, 0.1);
}

.type-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 10rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #999;
}

/* 参数表格 */
.specs-table {
  background: #f8f9fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.spec-row:last-child {
  border-bottom: none;
}

.spec-key {
  font-size: 26rpx;
  color: #666;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
}

/* 性能评分 */
.perf-section {
  background: #fff;
}

.perf-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.perf-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 18rpx;
}

.perf-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.perf-name {
  font-size: 26rpx;
  color: #333;
}

.perf-score {
  font-size: 26rpx;
  color: #4ecdc4;
  font-weight: bold;
}

.perf-bar {
  height: 14rpx;
  background: #e0e0e0;
  border-radius: 7rpx;
  overflow: hidden;
}

.perf-fill {
  height: 100%;
  border-radius: 7rpx;
}

/* 真实体验时间线 */
.exp-section {
  background: #fff;
}

.exp-timeline {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  padding-left: 20rpx;
  border-left: 3rpx solid #e0e0e0;
}

.exp-moment {
  position: relative;
  padding-left: 30rpx;
}

.moment-dot {
  position: absolute;
  left: -26rpx;
  top: 5rpx;
  width: 16rpx;
  height: 16rpx;
  background: #4ecdc4;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 0 3rpx #4ecdc4;
}

.moment-content {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 18rpx;
}

.moment-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.moment-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 优缺点 */
.pros-cons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pros-box, .cons-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.box-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.box-icon {
  font-size: 28rpx;
}

.box-title {
  font-size: 26rpx;
  font-weight: bold;
}

.pros-box .box-title {
  color: #2e7d32;
}

.cons-box .box-title {
  color: #e65100;
}

.box-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.box-item {
  display: flex;
  gap: 10rpx;
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
}

.item-bullet {
  font-weight: bold;
}

.pros-box .item-bullet {
  color: #4caf50;
}

.cons-box .item-bullet {
  color: #ff9800;
}

/* 适用人群 */
.suitable-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.suitable-tag {
  background: linear-gradient(135deg, #4ecdc4, #44a3aa);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
}

.usage-tip {
  display: flex;
  gap: 15rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 20rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 15rpx 25rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.action-icons {
  display: flex;
  gap: 30rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.icon-font {
  font-size: 36rpx;
}

.icon-text {
  font-size: 20rpx;
  color: #666;
}

.action-btn-group {
  flex: 1;
  display: flex;
  gap: 15rpx;
}

.btn-cart, .btn-buy {
  flex: 1;
  padding: 22rpx;
  border-radius: 50rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-cart {
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
  color: #666;
}

.btn-buy {
  background: linear-gradient(135deg, #4ecdc4, #44a3aa);
  color: #fff;
}
