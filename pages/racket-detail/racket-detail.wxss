.container {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 120rpx;
}

/* 顶部产品卡片 */
.product-header {
  margin-bottom: 20rpx;
}

.header-bg {
  padding: 40rpx 30rpx 50rpx;
}

.product-main {
  display: flex;
  gap: 30rpx;
}

.product-image-wrap {
  position: relative;
}

.product-icon {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}

.product-badge-row {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  display: flex;
  gap: 8rpx;
}

.badge {
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.badge-hot {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  color: #fff;
}

.badge-new {
  background: linear-gradient(135deg, #ffd700, #ffb800);
  color: #8b6914;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}

.product-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 15rpx;
}

.type-tag, .level-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stars {
  display: flex;
}

.star {
  color: #ffd700;
  font-size: 26rpx;
}

.rating-text {
  color: #ffd700;
  font-size: 26rpx;
  font-weight: bold;
}

.sales-text {
  color: rgba(255,255,255,0.7);
  font-size: 22rpx;
}

/* 价格区域 */
.price-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.current-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #e94560;
  font-weight: bold;
}

.price-num {
  font-size: 48rpx;
  color: #e94560;
  font-weight: bold;
}

.price-range {
  font-size: 22rpx;
  color: #999;
}

.color-options {
  font-size: 24rpx;
  color: #666;
}

.option-label {
  color: #999;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
  display: block;
}

/* 适用人群 */
.suitable-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 15rpx;
}

.suitable-tag {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
}

.not-suitable {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.not-suitable-title {
  font-size: 24rpx;
  color: #999;
}

.not-suitable-text {
  font-size: 24rpx;
  color: #666;
}

/* 参数表格 */
.specs-table {
  background: #f8f9fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.spec-row:last-child {
  border-bottom: none;
}

.spec-key {
  font-size: 26rpx;
  color: #666;
  width: 150rpx;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.spec-value.highlight {
  color: #e94560;
  font-weight: 500;
}

/* 性能评分区域 */
.perf-section {
  background: #fff;
}

.perf-grid {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.perf-category {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.perf-cat-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.perf-cat-icon {
  font-size: 28rpx;
}

.perf-cat-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.perf-bars {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.perf-bar-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #666;
  width: 130rpx;
}

.bar-track {
  flex: 1;
  height: 14rpx;
  background: #e0e0e0;
  border-radius: 7rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.bar-fill.attack {
  background: linear-gradient(90deg, #ff6b6b, #ee5a5a);
}

.bar-fill.speed {
  background: linear-gradient(90deg, #4ecdc4, #00d2d3);
}

.bar-fill.control {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.bar-fill.balance {
  background: linear-gradient(90deg, #ffd700, #ffb800);
}

.bar-fill.difficulty {
  background: linear-gradient(90deg, #a29bfe, #6c5ce7);
}

.bar-score {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  width: 45rpx;
  text-align: right;
}

/* 评测区域 */
.review-box {
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}

.pros-box {
  background: #f0fff4;
}

.cons-box {
  background: #fff8f0;
}

.review-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.review-icon {
  font-size: 28rpx;
}

.review-title {
  font-size: 26rpx;
  font-weight: bold;
}

.pros-box .review-title {
  color: #2e7d32;
}

.cons-box .review-title {
  color: #e65100;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.review-item {
  display: flex;
  gap: 8rpx;
}

.item-dot {
  color: #666;
  font-size: 24rpx;
}

.item-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
  flex: 1;
}

.review-summary {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.summary-icon {
  font-size: 28rpx;
}

.summary-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.summary-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

/* 常见问题 */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.faq-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 18rpx;
}

.faq-q {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.faq-icon {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.faq-question {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.faq-a {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding-left: 30rpx;
}

.faq-icon-a {
  background: #4ecdc4;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.faq-answer {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 15rpx 25rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.action-icons {
  display: flex;
  gap: 30rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.icon-font {
  font-size: 36rpx;
}

.icon-text {
  font-size: 20rpx;
  color: #666;
}

.action-btn-group {
  flex: 1;
  display: flex;
  gap: 15rpx;
}

.btn-similar, .btn-buy {
  flex: 1;
  padding: 22rpx;
  border-radius: 50rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-similar {
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
  color: #666;
}

.btn-buy {
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  color: #fff;
}
