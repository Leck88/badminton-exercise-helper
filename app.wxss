/* 全局样式 */
page {
  --primary: #e94560;
  --primary-dark: #c73e54;
  --secondary: #ffd700;
  --bg-dark: #1a1a2e;
  --bg-card: #ffffff;
  --text-primary: #333;
  --text-secondary: #666;
  --text-muted: #999;
  
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-hot {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  color: #fff;
}

.tag-new {
  background: linear-gradient(135deg, #4ecdc4, #44a3aa);
  color: #fff;
}

.tag-recommend {
  background: linear-gradient(135deg, #ffd700, #ffb800);
  color: #8b6914;
}

/* 性能条 */
.progress-bar {
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 价格样式 */
.price {
  color: var(--primary);
  font-size: 36rpx;
  font-weight: bold;
}

.price-original {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 10rpx;
}

/* 图片占位 */
.image-placeholder {
  background: linear-gradient(135deg, #f8f8f8, #e8e8e8);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 80rpx;
}
